NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# Phase 6 local Ollama AI workspace (server-only; placeholders only)
AI_ENABLED=false
AI_PROVIDER=ollama
AI_BASE_URL=http://127.0.0.1:11434/v1
AI_MODEL=<installed-ollama-model>
AI_API_KEY=
AI_REQUEST_TIMEOUT_MS=120000
AI_MAX_INPUT_CHARS=60000
AI_MAX_OUTPUT_TOKENS=4096
AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_INPUT_CHARS=200000
AI_RATE_LIMIT_WINDOW_MINUTES=60

# Phase 7 public demo / BYOK AI (server secrets are placeholders only)
BYOK_ENABLED=false
# Generate with: openssl rand -base64 32
BYOK_COOKIE_ENCRYPTION_KEY=
BYOK_SESSION_TTL_MINUTES=480
# Powerful server-only Supabase secret for metadata-only guest sessions/cleanup.
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Server-only; set to true only in local/test development. Production ignores the bypass token.
TURNSTILE_DEV_BYPASS=false
# Generate with: openssl rand -base64 32
GUEST_SESSION_HMAC_KEY=
GUEST_AI_MAX_REQUESTS_PER_HOUR=5
GUEST_AI_MAX_REQUESTS_PER_DAY=20
GUEST_AI_MAX_INPUT_CHARS=12000
